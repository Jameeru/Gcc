# Streamlit Cloud Secrets Configuration Template
# In Streamlit Cloud, go to "Settings" > "Secrets" and paste this content
# Replace all values with your actual credentials

# Database Configuration (Required)
#
# RECOMMENDED: set DATABASE_URL to your Supabase connection-pooler URI
# (Supabase dashboard > Settings > Database > Connection Pooling > "Session
# pooler" > URI). This host is IPv4-compatible. Streamlit Community Cloud has
# no IPv6 egress, so the direct host (db.<ref>.supabase.co) used by the
# SUPABASE_URL/KEY fallback below will fail with a DNS resolution error.
DATABASE_URL = "postgresql://postgres.<project_ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Fallback fields (only used if DATABASE_URL above is left blank).
# SUPABASE_KEY is the service-role API key -- it is NOT the database
# password and cannot be used to authenticate a Postgres connection.
SUPABASE_URL = "https://nkkmdzphiwmowwzzqqwx.supabase.co"
SUPABASE_KEY = "your-service-role-key-here"
SUPABASE_DB_PASSWORD = "your-actual-postgres-db-password-here"

# OpenAI Configuration (Required for AI research)
OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Gemini Configuration (Optional - for dual AI provider support)
GEMINI_API_KEY_1 = "AIza-your-gemini-api-key-here"
GEMINI_API_KEY_2 = "AIza-your-second-gemini-key-here"
GEMINI_MODEL = "gemini-2.0-flash"

# Encryption key for secure API key storage (Required)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY = "your-32-byte-base64-key-here"

# Optional Application Settings
LOG_LEVEL = "INFO"
MAX_UPLOAD_SIZE_MB = "50"
CACHE_EXPIRY_DAYS = "30"
SESSION_TIMEOUT_HOURS = "24"

# Database Settings
DB_POOL_SIZE = "5"
DB_POOL_RECYCLE = "3600"
DB_ECHO_SQL = "false"

# OpenAI Settings
OPENAI_MODEL = "gpt-4o"
OPENAI_MAX_TOKENS = "2000"
OPENAI_TEMPERATURE = "0.1"
OPENAI_MAX_RETRIES = "3"
OPENAI_RETRY_DELAY = "1.0"
OPENAI_MAX_RETRY_DELAY = "60.0"

# Application Settings
MAX_CONCURRENT_REQUESTS = "10"
DEBUG_MODE = "false"