# GCC Research Intelligence Platform - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Database Configuration (Required)
#
# RECOMMENDED for production (especially Streamlit Cloud): set DATABASE_URL
# directly to your Supabase connection-pooler URI. Get it from your Supabase
# project: Settings > Database > Connection Pooling > "Session pooler" (or
# "Transaction pooler") > URI. It looks like:
#   postgresql://postgres.<project_ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The pooler host is IPv4-compatible. The direct host (db.<ref>.supabase.co,
# built automatically below) is IPv6-only on most Supabase projects and will
# fail with "could not translate host name ... to address" on platforms
# without IPv6 egress, including Streamlit Community Cloud.
DATABASE_URL=

# Fallback (only used if DATABASE_URL is not set above). SUPABASE_KEY is the
# service-role *API* key, not a Postgres password -- it can never be used to
# authenticate a database connection. SUPABASE_DB_PASSWORD is the actual
# Postgres password for the `postgres` user, set when the project was created
# (or reset from Settings > Database > Reset database password).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key-here
SUPABASE_DB_PASSWORD=your-actual-postgres-db-password-here

# OpenAI Configuration (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Configuration (Optional bootstrap fallback)
# These env vars are only used if a key isn't already set via the in-app
# Settings tab. Once a key is saved there (encrypted at rest in the DB), it
# takes precedence over these env vars on every research call.
GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Encryption key for API keys stored via the Settings tab (Required if using
# the Settings UI to store keys in the DB). Generate with:
#   python3 -c "from src.utils.crypto import generate_encryption_key as g; print(g())"
SETTINGS_ENCRYPTION_KEY=your_32_byte_urlsafe_base64_key_here

# Optional Database Settings
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600
DB_ECHO_SQL=false

# Optional OpenAI Settings
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_RETRIES=3
OPENAI_RETRY_DELAY=1.0
OPENAI_MAX_RETRY_DELAY=60.0

# Optional Application Settings
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
CACHE_EXPIRY_DAYS=30
SESSION_TIMEOUT_HOURS=24
MAX_CONCURRENT_REQUESTS=10
DEBUG_MODE=false

# Example values for development:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key-with-full-access
# OPENAI_API_KEY=sk-your-openai-api-key-here
# GEMINI_API_KEY_1=AIza-your-gemini-api-key-here
# SETTINGS_ENCRYPTION_KEY=base64-urlsafe-32-byte-key-here